# ============================================================
# ai-service — Environment Variables
# Copy file này thành .env và điền giá trị thực
# KHÔNG commit file .env vào git
# ============================================================

PORT=8000
HOST=0.0.0.0

# OpenAI (chỉ dùng cho embeddings CV/JD — xem app/services/embeddings.py)
OPENAI_API_KEY=your_openai_api_key_here

# Groq (dùng cho agent1 resume-parser và agent2 matching)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Qdrant Vector DB
QDRANT_HOST=localhost
QDRANT_PORT=6333

# PostgreSQL (ai-service gọi trực tiếp để cập nhật kết quả agent)
DB_HOST=localhost
DB_PORT=5432
DB_USER=smart_user
DB_PASSWORD=smart_password
DB_NAME=smart_recruitment

# NestJS BE (callback URL để AI service notify khi agent hoàn thành)
BE_INTERNAL_URL=http://localhost:3000
BE_INTERNAL_SECRET=your-internal-api-secret-key
