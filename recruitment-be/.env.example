# ============================================================
# recruitment-be — Environment Variables
# Copy file này thành .env và điền giá trị thực
# KHÔNG commit file .env vào git
# ============================================================

# App
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=smart_user
DB_PASSWORD=smart_password
DB_NAME=smart_recruitment

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# AWS S3 (lưu file CV và PDF báo cáo)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=smart-recruitment-files

# Google OAuth (cho Recruiter dùng Google Calendar)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# OAuth token encryption (AES-256-GCM, phải đúng 32 ký tự)
OAUTH_ENCRYPTION_KEY=your-32-character-encryption-key!!

# AI Service (internal HTTP call từ NestJS → FastAPI)
AI_SERVICE_URL=http://localhost:8000

# Email (Nodemailer — gửi lịch phỏng vấn)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Smart Recruitment <noreply@smartrecruitment.com>"
