# ============================================================
# recruitment-be — Environment Variables
# Copy file này thành .env và điền giá trị thực
# KHÔNG commit file .env vào git
# ============================================================

# App
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# PostgreSQL
# Local/Docker: dùng DB_HOST/DB_PORT/DB_USER/DB_PASSWORD/DB_NAME
# Production (Neon): set DATABASE_URL — sẽ ghi đè các biến DB_* ở trên và bật SSL
DB_HOST=localhost
DB_PORT=5432
DB_USER=smart_user
DB_PASSWORD=smart_password
DB_NAME=smart_recruitment
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# Redis (BullMQ)
# Local/Docker: dùng REDIS_HOST/REDIS_PORT/REDIS_PASSWORD
# Production (Upstash): set REDIS_URL (rediss://...) — sẽ ghi đè các biến REDIS_* ở trên và bật TLS
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_URL=rediss://default:password@xxx.upstash.io:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Supabase Storage (lưu file CV và PDF báo cáo)
SUPABASE_URL=https://qqfuureaqkxwqypsnqwf.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_BUCKET=recruitment-files

# Google OAuth
# GOOGLE_LOGIN_CALLBACK_URL: dùng cho Candidate đăng nhập bằng Google
# GOOGLE_CALLBACK_URL: sẽ dùng cho Recruiter kết nối Google Calendar (scope khác)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_LOGIN_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/calendar/callback

# OAuth token encryption (AES-256-GCM, phải đúng 32 ký tự)
OAUTH_ENCRYPTION_KEY=your-32-character-encryption-key!!

# AI Service (internal HTTP call từ NestJS → FastAPI)
AI_SERVICE_URL=http://localhost:8000

# Email (Nodemailer — gửi lịch phỏng vấn)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Smart Recruitment <noreply@smartrecruitment.com>"
